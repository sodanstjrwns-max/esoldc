  <rect width="1200" height="630" fill="url(#bg)"/>
  <circle cx="1060" cy="120" r="70" fill="#FF9E80" opacity="0.85"/>
  <circle cx="1130" cy="520" r="50" fill="#B8AEE8" opacity="0.7"/>
  <circle cx="120" cy="560" r="40" fill="#7ED0BE" opacity="0.7"/>
  <text x="80" y="300" font-family="Pretendard,sans-serif" font-size="80" fill="#3B3349" font-weight="800">이솔치과의원</text>
